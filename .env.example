AGENT_PROVIDER=openai
API_URL=http://127.0.0.1:8317
BASE_URL=http://127.0.0.1:8317
API_KEY=replace-with-openai-compatible-proxy-key

# Optional explicit model overrides. If omitted, the server queries /v1/models
# and prefers Haiku for text turns, Sonnet/Haiku for vision turns.
AGENT_TEAM_MODELS=claude-haiku-4-5-20251001,claude-sonnet-4-6
OPENAI_TEXT_MODEL=
OPENAI_VISION_MODEL=
OPENAI_MODEL=
OPENAI_MAX_TOKENS=16000
AGENT_REACT_MAX_ITERATIONS=6
AGENT_FORCE_FIRST_WORLD_SURVEY=true
AGENT_FILE_LOGS=true
AGENT_CONSOLE_LOGS=true
AGENT_LOG_DIR=logs

# Browser URL controls:
#   &turnTime=120
#   &chatLang=English
#   &chatLanguage=Russian
#   &historySize=14
#   &memoryWindow=14
#   &memoryStrategy=sliding
#   &maxBatchesPerTurn=4

# Direct Anthropic provider is optional. The default path above is OpenAI-compatible.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=16000
