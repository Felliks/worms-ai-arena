# Build artifacts (regenerated by the build; keep out of git).
dist/
*.map
# Ignore loose/compiled JS, but keep the vendored libs (external/*.js, e.g.
# Tone.js) and the hand-written browser helper so a fresh clone is complete.
*.js
!external/*.js
!src/audio/SoundBufferLoader.js
*.config

# Legacy Visual Studio / .NET project files must not come back.
*.sln
*.csproj
*.csproj.user

# Local asset packs and manifests. Example manifests (*.example.json) are kept.
assets/worms-*/
assets/*.local.json
WAAss/
# Downloaded or generated music tracks stay local unless explicitly licensed.
assets/music/*
# Local video exports from the clip studio.
*.mp4
*.webm
